<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Grammar Focus — Verb Tenses in Context</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Roboto', sans-serif;
    }

    body {
      background: linear-gradient(145deg, #e9eff7 0%, #cddae9 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 24px 20px;
      color: #1e2a3e;
    }

    .exercise-card {
      background-color: #ffffff;
      border-radius: 32px;
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2), 0 1px 2px rgba(0, 0, 0, 0.05);
      width: 100%;
      max-width: 880px;
      overflow: hidden;
      transition: all 0.2s ease;
    }

    .header {
      background: linear-gradient(115deg, #1e3c5c 0%, #2b4c6e 100%);
      padding: 28px 32px;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }

    .header h1 {
      font-size: 1.9rem;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: white;
      margin-bottom: 8px;
      text-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .header p {
      font-size: 1rem;
      color: #d9e6f5;
      font-weight: 500;
    }

    .instruction {
      background-color: #f0f6fe;
      padding: 14px 28px;
      border-bottom: 1px solid #dce5f0;
      font-size: 0.95rem;
      color: #1e4663;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .instruction span {
      background-color: #2b4c6e;
      color: white;
      padding: 4px 12px;
      border-radius: 40px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .exercise-content {
      padding: 28px 32px 32px;
    }

    .sentences-list {
      display: flex;
      flex-direction: column;
      gap: 18px;
      margin-bottom: 28px;
    }

    .tense-item {
      background: #fefefe;
      border-radius: 20px;
      border: 1px solid #e6edf4;
      transition: all 0.2s;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.02);
    }

    .tense-item:hover {
      border-color: #cbdde9;
      background-color: #fdfdfd;
    }

    .sentence-row {
      padding: 18px 22px;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 8px;
      font-size: 1.05rem;
      line-height: 1.55;
      color: #1f3a4b;
    }

    .sentence-text {
      display: inline-flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 6px;
      flex: 1;
    }

    .subject {
      font-weight: 700;
      color: #1f5e8e;
      background: #eef3fc;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 0.9rem;
    }

    .base-sentence {
      display: inline;
    }

    select {
      margin: 0 4px;
      padding: 8px 14px;
      border-radius: 40px;
      border: 1.5px solid #cbdbe0;
      background-color: white;
      font-weight: 500;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Segoe UI', monospace;
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="%23455a6e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>');
      background-repeat: no-repeat;
      background-position: right 12px center;
      appearance: none;
      padding-right: 32px;
    }

    select:focus {
      outline: none;
      border-color: #2c7cb6;
      box-shadow: 0 0 0 3px rgba(44, 124, 182, 0.2);
    }

    select.correct-highlight {
      border-color: #2b8c4e;
      background-color: #edf7f0;
    }

    select.wrong-highlight {
      border-color: #d9534f;
      background-color: #fef6f5;
    }

    .tense-item.correct-border {
      border-left: 5px solid #2b8c4e;
      background-color: #f9fef7;
    }

    .tense-item.wrong-border {
      border-left: 5px solid #d9534f;
      background-color: #fff8f7;
    }

    .progress-area {
      margin: 20px 0 24px;
    }

    .progress-track {
      height: 10px;
      background-color: #e2e8f0;
      border-radius: 20px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #2c7cb6, #1f5e8e);
      width: 0%;
      border-radius: 20px;
      transition: width 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    .stats {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 0.8rem;
      color: #3e5a73;
      font-weight: 500;
    }

    .message-box {
      margin: 20px 0 18px;
      padding: 14px 18px;
      border-radius: 60px;
      text-align: center;
      font-weight: 600;
      display: none;
      backdrop-filter: blur(2px);
    }

    .success-msg {
      background: #e0f2e9;
      color: #1f6e43;
      border: 1px solid #b9dfc4;
    }

    .error-msg {
      background: #ffe8e6;
      color: #bc3f31;
      border: 1px solid #f5cdca;
    }

    .action-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-top: 10px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 12px 28px;
      border: none;
      border-radius: 48px;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: 0.2s;
      background-color: #edf2f7;
      color: #1e3a5f;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .btn-primary {
      background: linear-gradient(95deg, #1e5a7d, #144b6b);
      color: white;
      box-shadow: 0 4px 8px rgba(0,0,0,0.08);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      background: linear-gradient(95deg, #236e96, #1a577b);
      box-shadow: 0 8px 18px rgba(0,0,0,0.1);
    }

    .btn-secondary {
      background-color: #eef2f8;
      border: 1px solid #cbdde9;
    }

    .btn-secondary:hover {
      background-color: #e3eaf1;
      transform: translateY(-1px);
    }

    footer {
      background-color: #f8fafd;
      border-top: 1px solid #e2edf7;
      text-align: center;
      padding: 16px;
      font-size: 0.75rem;
      color: #6f8eac;
    }

    @media (max-width: 680px) {
      .exercise-content {
        padding: 20px;
      }
      .sentence-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }
      select {
        width: 100%;
        margin-top: 6px;
      }
      .header h1 {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body>
<div class="exercise-card">
  <div class="header">
    <h1>📘 Tense & Aspect — Real‑life Sentences</h1>
    <p>Complete each sentence with the correct verb form</p>
  </div>
  <div class="instruction">
    <span>🎯 Grammar focus</span> Present perfect, past continuous, future perfect, simple past, present simple, past perfect, etc.
    <span style="background:#5f7f9e;">based on screenshot pattern</span>
  </div>
  <div class="exercise-content">
    <div class="sentences-list" id="sentences-container">
      <!-- Each item mirrors the style: subject + sentence with a blank (dropdown) based on original tense exercise -->
    </div>

    <div class="progress-area">
      <div class="progress-track">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <div class="stats">
        <span>📝 Completion</span>
        <span id="percentText">0%</span>
      </div>
    </div>

    <div id="feedbackMessage" class="message-box"></div>

    <div class="action-buttons">
      <button class="btn btn-primary" id="checkAnswersBtn">✅ Check answers</button>
      <button class="btn btn-secondary" id="resetExerciseBtn">⟳ Reset all</button>
    </div>
  </div>
  <footer>
    🧠 Verb tenses practice · Inspired by real-life completed examples
  </footer>
</div>

<script>
  // ---- SENTENCE DATA - based on the given screenshot: Alan has been working, How old were you, Julia makes, I had been, will have been working, were you doing, talked, Were you at the dance...
  // Create 8 sentences covering various tenses: present perfect continuous, simple past, present simple, past perfect, future perfect, past continuous, simple past (question), past simple (to be)
  const sentencesData = [
    {
      id: 1,
      subject: "Alan",
      baseStart: "has been working ✔ on that painting",
      blankPos: "afterSubject", // not used; we'll embed dropdown as verb phrase choice
      fullDisplayPrefix: "Alan",
      verbOptions: ["has been working", "worked", "was working", "had worked"],
      correctVerb: "has been working",
      contextSuffix: "on that painting for six months.",
      hintExtra: "ongoing action from past until now"
    },
    {
      id: 2,
      subject: "How old",
      verbOptions: ["were", "was", "are", "have been"],
      correctVerb: "were",
      fullDisplayPrefix: "How old",
      contextSuffix: "you when you got married?",
      baseSentence: "How old ____ you when you got married?"
    },
    {
      id: 3,
      subject: "Julia",
      verbOptions: ["makes", "made", "has made", "is making"],
      correctVerb: "makes",
      contextSuffix: "dinner every time her mother visits.",
      fullDisplayPrefix: "Julia"
    },
    {
      id: 4,
      subject: "I",
      verbOptions: ["had been", "have been", "was", "went"],
      correctVerb: "had been",
      contextSuffix: "to Canada twice before I was ten.",
      fullDisplayPrefix: "I"
    },
    {
      id: 5,
      subject: "Next month Mr. Chang",
      verbOptions: ["will have been working", "will work", "has worked", "is working"],
      correctVerb: "will have been working",
      contextSuffix: "here for 20 years.",
      fullDisplayPrefix: "Next month Mr. Chang"
    },
    {
      id: 6,
      subject: "What",
      verbOptions: ["were you doing", "did you do", "have you done", "are you doing"],
      correctVerb: "were you doing",
      contextSuffix: "when I called?",
      fullDisplayPrefix: "What"
    },
    {
      id: 7,
      subject: "I",
      verbOptions: ["talked", "was talking", "have talked", "had talked"],
      correctVerb: "talked",
      contextSuffix: "to Jin on the phone yesterday.",
      fullDisplayPrefix: "I"
    },
    {
      id: 8,
      subject: "Were",
      verbOptions: ["Were", "Was", "Are", "Have"],
      correctVerb: "Were",
      contextSuffix: "you at the dance last Saturday night?",
      fullDisplayPrefix: "Were",
      customSelect: true
    }
  ];

  // build dynamic selects references
  let selectElements = [];
  let correctMap = {};

  function buildExercise() {
    const container = document.getElementById('sentences-container');
    container.innerHTML = '';
    selectElements = [];
    correctMap = {};

    sentencesData.forEach((item, idx) => {
      const qId = `q_${item.id}`;
      let selectHtml = '';
      let sentenceDisplay = '';

      if (item.id === 2) {
        // "How old ____ you when you got married?"
        sentenceDisplay = `How old <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> you when you got married?`;
      } 
      else if (item.id === 6) {
        // What ____ when I called?
        sentenceDisplay = `What <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> when I called?`;
      }
      else if (item.id === 8) {
        // Were / Was you at the dance?
        sentenceDisplay = `<select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> you at the dance last Saturday night?`;
      }
      else if (item.id === 1) {
        sentenceDisplay = `${item.fullDisplayPrefix} <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> ${item.contextSuffix}`;
      }
      else if (item.id === 3) {
        sentenceDisplay = `${item.fullDisplayPrefix} <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> ${item.contextSuffix}`;
      }
      else if (item.id === 4) {
        sentenceDisplay = `${item.fullDisplayPrefix} <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> ${item.contextSuffix}`;
      }
      else if (item.id === 5) {
        sentenceDisplay = `${item.fullDisplayPrefix} <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> ${item.contextSuffix}`;
      }
      else if (item.id === 7) {
        sentenceDisplay = `${item.fullDisplayPrefix} <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> ${item.contextSuffix}`;
      }
      else {
        // fallback generic
        sentenceDisplay = `${item.fullDisplayPrefix || item.subject} <select id="${qId}" class="tense-select">${generateOptions(item.verbOptions)}</select> ${item.contextSuffix || ''}`;
      }

      const sentenceDiv = document.createElement('div');
      sentenceDiv.className = 'tense-item';
      sentenceDiv.setAttribute('data-item-id', item.id);
      const rowDiv = document.createElement('div');
      rowDiv.className = 'sentence-row';
      const textSpan = document.createElement('div');
      textSpan.className = 'sentence-text';
      textSpan.innerHTML = sentenceDisplay;
      rowDiv.appendChild(textSpan);
      sentenceDiv.appendChild(rowDiv);
      container.appendChild(sentenceDiv);

      // store correct answer mapping
      correctMap[qId] = item.correctVerb;
      const selectEl = document.getElementById(qId);
      if (selectEl) {
        selectElements.push(selectEl);
        // event listeners for progress & clearing global check style
        selectEl.addEventListener('change', () => {
          removeGlobalHighlight();
          updateProgressOnly();
          hideMessages();
        });
      }
    });
    updateProgressOnly();
  }

  function generateOptions(optionsArray) {
    let opts = '<option value="">— select verb —</option>';
    optionsArray.forEach(opt => {
      opts += `<option value="${opt.replace(/"/g, '&quot;')}">${opt}</option>`;
    });
    return opts;
  }

  function removeGlobalHighlight() {
    // removes highlight classes from all selects and parent containers
    selectElements.forEach(select => {
      select.classList.remove('correct-highlight', 'wrong-highlight');
      const parentItem = select.closest('.tense-item');
      if (parentItem) {
        parentItem.classList.remove('correct-border', 'wrong-border');
      }
    });
  }

  function hideMessages() {
    const msgDiv = document.getElementById('feedbackMessage');
    if (msgDiv) msgDiv.style.display = 'none';
  }

  function updateProgressOnly() {
    let answered = 0;
    selectElements.forEach(sel => {
      if (sel.value && sel.value !== '') answered++;
    });
    const percent = (answered / selectElements.length) * 100;
    const fillBar = document.getElementById('progressFill');
    const percentSpan = document.getElementById('percentText');
    if (fillBar) fillBar.style.width = percent + '%';
    if (percentSpan) percentSpan.innerText = Math.round(percent) + '%';
  }

  function checkAllAnswers() {
    let allSelected = true;
    let allCorrect = true;

    // reset all highlight classes first
    selectElements.forEach(select => {
      select.classList.remove('correct-highlight', 'wrong-highlight');
      const parentDiv = select.closest('.tense-item');
      if (parentDiv) parentDiv.classList.remove('correct-border', 'wrong-border');
    });

    // check each
    for (let select of selectElements) {
      const selectedVal = select.value;
      const qId = select.id;
      const correctVal = correctMap[qId];
      if (!selectedVal || selectedVal === '') {
        allSelected = false;
        continue;
      }
      const isCorrect = (selectedVal === correctVal);
      if (!isCorrect) allCorrect = false;
      // apply style
      if (isCorrect) {
        select.classList.add('correct-highlight');
        const parentItem = select.closest('.tense-item');
        if (parentItem) parentItem.classList.add('correct-border');
      } else {
        select.classList.add('wrong-highlight');
        const parentItem = select.closest('.tense-item');
        if (parentItem) parentItem.classList.add('wrong-border');
      }
    }

    const msgBox = document.getElementById('feedbackMessage');
    msgBox.classList.remove('success-msg', 'error-msg');
    msgBox.style.display = 'block';

    if (!allSelected) {
      msgBox.textContent = '⚠️ Please select an answer for every sentence before checking.';
      msgBox.classList.add('error-msg');
    } else if (allCorrect) {
      msgBox.textContent = '🎉 Excellent! All verb tenses are correct. Perfect grammar!';
      msgBox.classList.add('success-msg');
    } else {
      msgBox.textContent = '📌 Some verb forms are incorrect. Review the tense timeline and try again.';
      msgBox.classList.add('error-msg');
    }
  }

  function resetExercise() {
    selectElements.forEach(select => {
      select.value = '';
      select.classList.remove('correct-highlight', 'wrong-highlight');
      const parentDiv = select.closest('.tense-item');
      if (parentDiv) parentDiv.classList.remove('correct-border', 'wrong-border');
    });
    updateProgressOnly();
    const msgBox = document.getElementById('feedbackMessage');
    msgBox.style.display = 'none';
    msgBox.classList.remove('success-msg', 'error-msg');
  }

  // helper to make sure answer checking removes previous highlights and re-evaluates
  function handleCheck() {
    // we remove previous static highlights but reapply based on current selection
    selectElements.forEach(select => {
      select.classList.remove('correct-highlight', 'wrong-highlight');
      const parentItem = select.closest('.tense-item');
      if (parentItem) parentItem.classList.remove('correct-border', 'wrong-border');
    });
    checkAllAnswers(); // this reapplies correct/wrong styles
  }

  function init() {
    buildExercise();
    const checkBtn = document.getElementById('checkAnswersBtn');
    const resetBtn = document.getElementById('resetExerciseBtn');
    if (checkBtn) checkBtn.addEventListener('click', handleCheck);
    if (resetBtn) resetBtn.addEventListener('click', resetExercise);
  }

  init();
</script>
</body>
</html>
